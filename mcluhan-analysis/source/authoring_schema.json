{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Authoring Output Schema — The Model is the Massage",
  "version": "1.0",
  "description": "Schema for Phase 3 authoring output: text options and design specifications per spread.",
  "type": "object",
  "required": ["version", "generated", "spreads"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "generated": { "type": "string", "format": "date-time" },
    "generator": { "type": "string" },
    "spread_range": { "type": "string", "description": "e.g. 'spread_006-spread_025'" },
    "spreads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["spread_id", "movement", "text_options", "design_specs"],
        "properties": {
          "spread_id": { "type": "string", "pattern": "^spread_\\d{3}$" },
          "movement": {
            "type": "string",
            "enum": ["prologue", "movement_1_environment", "movement_2_acceleration", "hinge", "movement_3_dreamscape"]
          },
          "theme": { "type": "string", "description": "From content_plan.contemporary_plan.theme" },

          "text_options": {
            "type": "array",
            "minItems": 3,
            "maxItems": 5,
            "items": {
              "type": "object",
              "required": ["option_id", "label", "display_text", "body_text", "rationale"],
              "properties": {
                "option_id": { "type": "string", "pattern": "^[a-c]$" },
                "label": {
                  "type": "string",
                  "description": "Short label for the option, e.g. 'The ambient period', 'Confrontational address'"
                },
                "display_text": {
                  "type": ["string", "null"],
                  "description": "Large-scale typographic text for the spread. Null if no display text."
                },
                "body_text": {
                  "type": ["string", "null"],
                  "description": "Smaller prose/quotation text. Null if no body text."
                },
                "caption_text": {
                  "type": ["string", "null"],
                  "description": "Caption, statistic, or attribution text. Null if none."
                },
                "quotations_used": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["text", "attribution"],
                    "properties": {
                      "text": { "type": "string" },
                      "attribution": { "type": "string" },
                      "source": { "type": "string" }
                    }
                  }
                },
                "voice_register": {
                  "type": "string",
                  "description": "The tonal quality: e.g. 'declarative', 'clinical', 'lyrical', 'confrontational', 'quiet'"
                },
                "rhetorical_strategy": {
                  "type": "string",
                  "enum": ["assertion", "confrontation", "juxtaposition", "accumulation", "disruption", "provocation", "invocation", "dramatization", "quieting", "sensory_overload", "humor", "demonstration", "interpellation", "defamiliarization", "call_and_response"]
                },
                "rationale": {
                  "type": "string",
                  "description": "Why this option works for this spread — how it serves the argument, movement, and rhythm."
                },
                "word_count": { "type": "integer" }
              }
            }
          },

          "design_specs": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "object",
              "required": ["spec_id", "label", "layout", "typography", "image_direction", "rationale"],
              "properties": {
                "spec_id": { "type": "string", "pattern": "^[1-3]$" },
                "label": { "type": "string", "description": "Short label: e.g. 'Full-bleed typographic', 'Split asymmetric'" },
                "layout": {
                  "type": "object",
                  "required": ["type", "description"],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["full_bleed_image", "full_bleed_typography", "split_asymmetric", "split_symmetric", "text_dominant", "image_dominant", "text_over_image", "minimal_sparse", "dense_collage", "diagram_with_text"]
                    },
                    "description": { "type": "string" },
                    "left_page": { "type": "string", "description": "What occupies the left page" },
                    "right_page": { "type": "string", "description": "What occupies the right page" },
                    "gutter_treatment": {
                      "type": "string",
                      "enum": ["continuous", "divided", "bridged"],
                      "description": "Whether content flows across, is split by, or bridges the gutter"
                    },
                    "orientation": {
                      "type": "string",
                      "enum": ["landscape", "portrait", "rotated_90"],
                      "default": "landscape"
                    }
                  }
                },
                "typography": {
                  "type": "object",
                  "properties": {
                    "display_face": {
                      "type": "string",
                      "description": "Font suggestion for display text: e.g. 'heavy grotesque sans', 'condensed slab serif'"
                    },
                    "body_face": {
                      "type": "string",
                      "description": "Font suggestion for body text: e.g. 'humanist serif', 'monospace'"
                    },
                    "display_scale": {
                      "type": "string",
                      "enum": ["architectural", "headline", "subhead", "body", "caption"],
                      "description": "Relative scale of display text"
                    },
                    "color_treatment": {
                      "type": "string",
                      "enum": ["black_on_white", "white_on_black", "reversed", "mixed"],
                      "description": "B&W treatment"
                    },
                    "special_treatment": {
                      "type": ["string", "null"],
                      "description": "Rotated, fragmented, overlaid, etc."
                    }
                  }
                },
                "image_direction": {
                  "type": "object",
                  "properties": {
                    "approach": {
                      "type": "string",
                      "enum": ["generated", "found", "graphic_symbol", "typography_only", "none", "combination"]
                    },
                    "subject": { "type": "string" },
                    "mood": { "type": "string" },
                    "bw_treatment": {
                      "type": "string",
                      "description": "High contrast, soft gray, solarized, halftone, etc."
                    },
                    "scale": {
                      "type": "string",
                      "enum": ["full_bleed", "half_page", "quarter_page", "inset", "icon"]
                    }
                  }
                },
                "density": {
                  "type": "string",
                  "enum": ["sparse", "moderate", "dense", "overwhelming"],
                  "description": "Overall visual density of the spread"
                },
                "tone": {
                  "type": "string",
                  "enum": ["light", "dark", "balanced", "high_contrast"],
                  "description": "Overall light/dark balance"
                },
                "svg_wireframe": {
                  "type": "string",
                  "description": "SVG markup string for the annotated wireframe"
                },
                "rationale": { "type": "string" }
              }
            }
          },

          "selected_text": {
            "type": ["string", "null"],
            "description": "option_id of the selected text option (null = not yet selected)"
          },
          "selected_design": {
            "type": ["string", "null"],
            "description": "spec_id of the selected design spec (null = not yet selected)"
          },
          "reviewer_notes": {
            "type": ["string", "null"],
            "description": "Human reviewer notes"
          },
          "dependency_flags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Adjacent spreads affected by selections on this spread"
          }
        }
      }
    }
  }
}
